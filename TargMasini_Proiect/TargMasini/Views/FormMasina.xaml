<Window x:Class="TargMasini.Views.FormMasina"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tranzacție mașină"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding"    Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height"  Value="30"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ErrTxt" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,1,0,4"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <!-- CONCEPT WPF: ScrollViewer pentru formulare lungi (Lab 8) -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,18,24,18">

            <TextBlock x:Name="TbTitluForm" FontSize="17" FontWeight="Bold"
                       Foreground="#1565C0" Margin="0,0,0,14"/>

            <!-- Vânzător -->
            <Label Content="Nume Vânzător *"/>
            <TextBox x:Name="TxtVanzator"/>
            <TextBlock x:Name="ErrVanzator" Style="{StaticResource ErrTxt}"
                       Text="Câmpul este obligatoriu!"/>

            <!-- Cumpărător -->
            <Label Content="Nume Cumpărător *"/>
            <TextBox x:Name="TxtCumparator"/>
            <TextBlock x:Name="ErrCumparator" Style="{StaticResource ErrTxt}"
                       Text="Câmpul este obligatoriu!"/>

            <!-- Firma -->
            <Label Content="Firmă Auto *"/>
            <!-- CONCEPT WPF: ComboBox cu text editabil (Lab 9) -->
            <ComboBox x:Name="CmbFirma" Height="30" IsEditable="True"
                      IsTextSearchEnabled="True">
                <ComboBoxItem Content="Dacia"/>
                <ComboBoxItem Content="BMW"/>
                <ComboBoxItem Content="Ford"/>
                <ComboBoxItem Content="Opel"/>
                <ComboBoxItem Content="Toyota"/>
                <ComboBoxItem Content="Volkswagen"/>
                <ComboBoxItem Content="Renault"/>
                <ComboBoxItem Content="Mercedes"/>
                <ComboBoxItem Content="Audi"/>
                <ComboBoxItem Content="Skoda"/>
            </ComboBox>
            <TextBlock x:Name="ErrFirma" Style="{StaticResource ErrTxt}"
                       Text="Selectați sau introduceți firma!"/>

            <!-- Model -->
            <Label Content="Model *"/>
            <TextBox x:Name="TxtModel"/>
            <TextBlock x:Name="ErrModel" Style="{StaticResource ErrTxt}"
                       Text="Câmpul este obligatoriu!"/>

            <!-- An fabricatie -->
            <Label Content="An Fabricație *"/>
            <TextBox x:Name="TxtAn"/>
            <TextBlock x:Name="ErrAn" Style="{StaticResource ErrTxt}"
                       Text="Introduceți un an valid (ex: 2020)!"/>

            <!-- Culoare -->
            <Label Content="Culoare *"/>
            <TextBox x:Name="TxtCuloare"/>
            <TextBlock x:Name="ErrCuloare" Style="{StaticResource ErrTxt}"
                       Text="Câmpul este obligatoriu!"/>

            <!-- Optiuni – CheckBox (Lab 8/11) -->
            <Label Content="Opțiuni dotări"/>
            <WrapPanel Margin="0,2,0,6">
                <CheckBox x:Name="ChkAC"         Content="Aer condiționat" Margin="0,0,12,4"/>
                <CheckBox x:Name="ChkNavigatie"  Content="Navigație"       Margin="0,0,12,4"/>
                <CheckBox x:Name="ChkSenzori"    Content="Senzori parcare" Margin="0,0,12,4"/>
                <CheckBox x:Name="ChkPiele"      Content="Tapițerie piele" Margin="0,0,12,4"/>
                <CheckBox x:Name="ChkCameraRev"  Content="Cameră rev."     Margin="0,0,12,4"/>
                <CheckBox x:Name="ChkSunroof"    Content="Sunroof"         Margin="0,0,12,4"/>
            </WrapPanel>

            <!-- Data tranzactie -->
            <Label Content="Data Tranzacției *"/>
            <!-- CONCEPT WPF: DatePicker (Lab 9) -->
            <DatePicker x:Name="DpData" Height="30"/>
            <TextBlock x:Name="ErrData" Style="{StaticResource ErrTxt}"
                       Text="Selectați data tranzacției!"/>

            <!-- Pret -->
            <Label Content="Preț (EUR) *"/>
            <TextBox x:Name="TxtPret"/>
            <TextBlock x:Name="ErrPret" Style="{StaticResource ErrTxt}"
                       Text="Introduceți un preț valid (ex: 15000)!"/>

            <!-- Mesaj avertizare (duplicat in aceeasi zi) -->
            <Border x:Name="PanelAvertizare"
                    Background="#FFF3E0" BorderBrush="#FFA000"
                    BorderThickness="1" CornerRadius="4"
                    Padding="10,8" Margin="0,8,0,4"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbAvertizare"
                           TextWrapping="Wrap" Foreground="#E65100"/>
            </Border>

            <!-- Butoane -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="BtnSalveaza" Content="💾 Salvează"
                        Width="110" Height="36"
                        Background="#1565C0" Foreground="White"
                        FontWeight="Bold" BorderBrush="Transparent"
                        Cursor="Hand"
                        Click="BtnSalveaza_Click"/>
                <Button Content="Anulează" Width="90" Height="36"
                        Margin="8,0,0,0" IsCancel="True"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
